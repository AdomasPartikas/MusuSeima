# Site Configuration
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# Title shown in the browser tab and header
VITE_SITE_TITLE=Musu Seima

# Public read-only Google Drive folder link
# Replace REPLACE_WITH_FOLDER_ID with your actual Drive folder ID
VITE_DRIVE_ARCHIVE_URL=https://drive.google.com/drive/folders/REPLACE_WITH_FOLDER_ID
